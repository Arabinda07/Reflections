# Supabase (client-side — these are public anon keys, safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase (server-side — used by Vercel serverless functions in /api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (server-side only — used by /api/ai.ts)
GEMINI_API_KEY=your-gemini-api-key

# Sentry (client-side — error monitoring, optional in dev)

# Razorpay (payments — INR-native)
VITE_RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxx