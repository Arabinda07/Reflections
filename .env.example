# Supabase (client-side — these are public anon keys, safe to expose in browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase Auth URL allow-list
# Site URL: https://www.reflections-sanctuary.space
# Redirect URLs:
# - https://www.reflections-sanctuary.space/auth/callback
# - https://www.reflections-sanctuary.space/auth/callback?next=/reset-password
# - http://localhost:3000/auth/callback
# - http://localhost:3000/auth/callback?next=/reset-password
# - https://*-*.vercel.app/auth/callback
# - https://*-*.vercel.app/auth/callback?next=/reset-password
# - com.arabinda.reflections://auth/callback

# Supabase (server-side — used by Vercel serverless functions in /api)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Gemini AI (server-side only — used by /api/ai.ts)
GEMINI_API_KEY=your-gemini-api-key

# Razorpay
VITE_RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_ID=your-razorpay-key-id
RAZORPAY_KEY_SECRET=your-razorpay-key-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret
RAZORPAY_WEEKLY_PLAN_ID=plan_weekly_id
RAZORPAY_MONTHLY_PLAN_ID=plan_monthly_id

# Supabase Service Role Key (Server-side)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase Edge Function shared secret for send-welcome-email
FUNCTION_SECRET=your-shared-function-secret
